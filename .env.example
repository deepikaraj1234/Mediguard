# GEMINI_API_KEY: Required for Gemini AI API calls.
# On Render, add this in the "Environment Variables" section of your service dashboard.
GEMINI_API_KEY="your_actual_api_key_here"

# JWT_SECRET: Secret key for signing authentication tokens.
# On Render, add this as a secret environment variable.
JWT_SECRET="your_random_secret_string"

# NODE_ENV: Set to "production" on Render.
NODE_ENV="production"

# APP_URL: The URL where this app is hosted (e.g., https://mediguard.onrender.com).
APP_URL="your_render_url"
